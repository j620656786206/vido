{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api",
  "projectType": "application",
  "tags": ["type:app", "platform:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o ../../dist/apps/api/main ./cmd/api",
        "cwd": "apps/api"
      },
      "outputs": ["{workspaceRoot}/dist/apps/api"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "GIN_MODE=debug go run ./cmd/api",
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./... -v",
        "cwd": "apps/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go vet ./... && STATICCHECK_BIN=\"$(go env GOPATH)/bin/staticcheck-2026.1\" && { [ -x \"$STATICCHECK_BIN\" ] || { echo '→ Installing staticcheck@2026.1 (first-time setup, ~10s)...' >&2 && STATICCHECK_TMP=$(mktemp -d) && GOBIN=\"$STATICCHECK_TMP\" go install honnef.co/go/tools/cmd/staticcheck@2026.1 && mv \"$STATICCHECK_TMP/staticcheck\" \"$STATICCHECK_BIN\" && rmdir \"$STATICCHECK_TMP\"; }; } && \"$STATICCHECK_BIN\" ./...",
        "cwd": "apps/api"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go fmt ./...",
        "cwd": "apps/api"
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod tidy",
        "cwd": "apps/api"
      }
    }
  }
}
